NODE_ENV=development
PORT=3000
LOG_LEVEL=info
LOG_ACCESS_KEY=change-this-random-log-view-key
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_USER_TOKEN=xoxp-your-user-token-with-users.profile.write
SLACK_CLIENT_ID=123456789.123456789
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_OAUTH_REDIRECT_URI=https://your-domain/slack/oauth/callback
TOKEN_ENCRYPTION_KEY=change-this-long-random-secret-at-least-32-chars
SLACK_SIGNING_SECRET=your-signing-secret
AFK_CHANNEL_ID=C0123456789
REDIS_URL=redis://localhost:6379
RATE_LIMIT_POINTS=5
RATE_LIMIT_DURATION_SECONDS=60
AFK_QUEUE_NAME=afk-auto-return
SLACK_HISTORY_POLLING_ENABLED=true
SLACK_HISTORY_POLLING_INTERVAL_MS=5000
SLACK_STATUS_ENABLED=true
AFK_STATUS_EMOJI=:sleeping:
AFK_STATUS_TEXT=AFK
